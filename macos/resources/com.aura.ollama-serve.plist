<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aura.ollama-serve</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/Aura Desktop.app/Contents/Resources/ollama-bundle/ollama</string>
        <string>serve</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>OLLAMA_ORIGINS</key>
        <string>*</string>
        <key>HOME</key>
        <string>__USER_HOME__</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/tmp/aura-ollama.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/aura-ollama.err</string>
</dict>
</plist>
